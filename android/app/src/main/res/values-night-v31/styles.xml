<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark mode variant for Android 12+ SplashScreen API.
         Brand purple works equally well in both themes. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowSplashScreenBackground">@color/launch_background_color</item>
        <item name="android:windowSplashScreenAnimatedIcon">@mipmap/launcher_icon</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@color/launch_background_color</item>
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>

    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
